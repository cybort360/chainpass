# =============================================================================
# ChainPass — copy to `.env` at this repo root for local dev / reference for deploy
# =============================================================================
# Vercel: install/build use `npx pnpm@${version}` from root package.json
# "packageManager" so the CLI matches the lockfile (avoids image default pnpm).
# Never commit real secrets. In production, set these in your host (Vercel,
# Railway, Fly.io, Docker, etc.). Forge deploy uses some of these from the shell
# or a local `.env` in `contracts/` — see contracts README.
# =============================================================================

# --- Chain (Monad testnet) ----------------------------------------------------
RPC_URL=https://testnet-rpc.monad.xyz

# --- Client (Vite in client/) — copy client/.env.example → client/.env ------------
# Browser vars use the VITE_ prefix (see client/.env.example). Root file keeps
# TICKET_CONTRACT_ADDRESS for API + indexer below.

# --- API (server/api) ---------------------------------------------------------
PORT=3001
# CORS: API allows all origins (hackathon). Tighten before production.
# HMAC secret for signed QR payloads (POST /api/v1/qr/payload, /api/v1/qr/verify).
# Use a long random string in production (e.g. openssl rand -hex 32).
QR_SIGNING_SECRET=change-me-to-a-long-random-string
# TTL in seconds for signed payload (default 30 if unset; max 3600 enforced in code)
QR_TTL_SECONDS=30

# --- Postgres (shared: API + indexer + seed scripts) ------------------------
# Local Docker default matches tooling/docker-compose.yml
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chainpass
# After DB is up, optional: seed route labels for GET /api/v1/routes
#   pnpm --filter @chainpass/api run seed:route-labels
# Optional: when POST /api/v1/routes includes priceMon, merge into config/nigeria-routes.json
# (API process must be able to read/write that path — typical for local dev, not for serverless).
# NIGERIA_ROUTES_JSON_PATH=   # absolute path; default: repo config/nigeria-routes.json from API source tree
# NIGERIA_ROUTES_SYNC=1       # set to 0 to disable writing the JSON file

# --- Indexer (server/indexer) -------------------------------------------------
# Deployed ChainPassTicket address (required for indexer). Must match the contract you want
# to index; after redeploying a new contract, update this and INDEXER_FROM_BLOCK.
TICKET_CONTRACT_ADDRESS=0x5aB0d9D34Bf3e187bc29A72e0bceA9d6482f3ED4
# First block to scan when ticket_events is empty. After a NEW contract deploy: clear
# ticket_events (pnpm --filter @chainpass/indexer run db:clear-ticket-events), set this to
# the new deployment block, restart indexer. On-chain totalMinted/totalBurned always refer
# to the current contract only (no retroactive history across addresses).
INDEXER_FROM_BLOCK=23060921
# Poll interval (ms, min 500) and max blocks per eth_getLogs batch
INDEXER_POLL_MS=4000
INDEXER_BLOCK_CHUNK=100

# --- Optional: sync per-route fares (config/nigeria-routes.json → chain) -------
# Repo root: DRY_RUN=1 pnpm sync-route-prices  |  pnpm sync-route-prices
# Uses PRIVATE_KEY (admin) + TICKET_CONTRACT_ADDRESS. See config/README.md.

# --- Contracts: forge script (script/DeployChainPass.s.sol) -------------------
# Required for broadcast: uint256 hex private key (do NOT commit real keys)
# PRIVATE_KEY=0x...
# Optional overrides (defaults: deployer for treasury / minter / burner)
# METADATA_BASE_URI=https://api.example.com/metadata/
# TREASURY_ADDRESS=0x...
# MINT_PRICE_WEI=0
# MINTER_ADDRESS=0x...
# BURNER_ADDRESS=0x...
