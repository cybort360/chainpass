# API service — copy or set in your host (Railway, Fly, Docker, etc.).
# Monorepo reference: `../../.env.example`

PORT=3001
# CORS: API allows all origins (hackathon). Tighten before production.
QR_SIGNING_SECRET=change-me-to-a-long-random-string
QR_TTL_SECONDS=30

# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.acxumpkrbmzlmrxrhsll:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.acxumpkrbmzlmrxrhsll:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"