# Indexer worker — copy or set in your host.
# Monorepo reference: `../../.env.example`

RPC_URL=https://testnet-rpc.monad.xyz
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hoppr

# Deployed ChainPassTicket (must match client / API env)
TICKET_CONTRACT_ADDRESS=0x5aB0d9D34Bf3e187bc29A72e0bceA9d6482f3ED4

# Block where this contract was created (not chain genesis). After replacing the contract,
# truncate ticket_events (see db:clear-ticket-events) and set this to the new deploy block.
# Headline lifetime mint/burn counts are also on-chain: totalMinted() / totalBurned() on the contract.
INDEXER_FROM_BLOCK=23060921

INDEXER_POLL_MS=4000
# Max blocks per eth_getLogs batch (Monad public RPC caps at 100; larger values are clamped)
INDEXER_BLOCK_CHUNK=100
