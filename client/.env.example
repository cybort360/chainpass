# ChainPass client (Vite) — copy to `client/.env` (gitignored)

# Privy — https://dashboard.privy.io — create an app and paste the App ID.
# In the dashboard, add allowed origins: http://localhost:5173, production URL, and http://YOUR_LAN_IP:5173 for phone testing.
# Login methods: disable Email (and any unused methods) under Login methods so the app stays wallet-only; SDK also sets loginMethods: ['wallet'].
# Some mobile wallets (e.g. Rainbow) do not support testnets as the default chain; Monad testnet may fail to connect there.
VITE_PRIVY_APP_ID=
# Optional: App Client ID if you use separate dashboard app clients per environment.
# VITE_PRIVY_CLIENT_ID=

# Deployed ChainPassTicket on Monad testnet (must match root TICKET_CONTRACT_ADDRESS).
# Redeploy = new address; on-chain totalMinted/totalBurned reset for that deployment.
VITE_CHAINPASS_CONTRACT_ADDRESS=0x33250106008ac99Fd169596D04b359ACf4cDc1C5

# ChainPass API (QR signing, operator, routes). No trailing slash.
VITE_CHAINPASS_API_URL=http://localhost:3001
# On your LAN (phone testing): use this machine’s IP, e.g. http://192.168.1.42:3001 — not localhost.
# Start API with the same machine; Windows Firewall may need to allow inbound 3001 + 5173.

# Stored on-chain with each `purchaseTicket` mint (demo may use zero address)
VITE_DEFAULT_OPERATOR_ADDRESS=0x0000000000000000000000000000000000000000
