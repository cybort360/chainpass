# Foundry deploy — copy to `.env` in this folder (never commit real keys).
# Full stack env reference: repo root `.env.example`

RPC_URL=https://testnet-rpc.monad.xyz

# Required for --broadcast (hex private key, uint256)
PRIVATE_KEY=

# Optional — defaults shown in script/DeployChainPass.s.sol
# METADATA_BASE_URI=
# TREASURY_ADDRESS=
# MINT_PRICE_WEI=0
# MINTER_ADDRESS=
# BURNER_ADDRESS=

# --- ConfigureUsdc.s.sol ---
# CONTRACT_ADDRESS=0x...          deployed ChainPassTicket
# USDC_TOKEN=0xf817257fed379853cDe0fa4F97AB987181B0Ab9E   (Monad testnet USDC)
# USDC_PRICE=100000               default price in 6-decimal USDC (100000 = $0.10)
# USDC_ROUTE_IDS=                 optional comma-separated route IDs for per-route overrides
# USDC_ROUTE_PRICES=              optional comma-separated prices matching USDC_ROUTE_IDS
